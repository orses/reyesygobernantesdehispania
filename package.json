    "idb-keyval": "6.2.6",
    "lucide-react": "1.23.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "7.18.1",
    "recharts": "3.9.1",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "22.20.0",
    "@types/react": "19.2.17",
