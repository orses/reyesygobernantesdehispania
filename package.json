    "lucide-react": "1.25.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "10.1.0",
    "react-router-dom": "7.18.1",
    "recharts": "3.9.2",
    "remark-breaks": "4.0.0",
    "remark-gfm": "4.0.1",
    "tailwind-merge": "3.6.0"
  },
